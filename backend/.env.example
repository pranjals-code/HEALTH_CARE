# Healthcare System Backend Configuration

# Database
DATABASE_URL=postgresql://healthcare_user:secure_password@localhost:5432/healthcare_system

# JWT Configuration
SECRET_KEY=your-super-secret-key-generate-a-new-one-for-production-use-python-secrets
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Service
SERVICE_NAME=healthcare-auth-service
SERVICE_VERSION=0.1.0
API_V1_PREFIX=/api/v1

# Environment
ENVIRONMENT=development
DEBUG=True

# Allowed CORS origins (comma-separated in production .env)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000

# Elasticsearch
ELASTICSEARCH_ENABLED=True
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_PATIENT_INDEX=patients
